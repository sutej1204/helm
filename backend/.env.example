# Helm backend — copy to `.env` for local dev. Don't commit `.env`.

# Postgres connection. Use Render's External URL for local dev, Internal for in-Render.
DATABASE_URL=postgresql://USER:PASS@HOST/DB

# Optional: shared bearer token. When unset, auth is disabled (handy for local dev).
# Set this on Render and have the frontend send it.
HELM_API_TOKEN=

# Static SPA root (relative to backend/). Dockerfile copies the React build here.
STATIC_DIR=app/static

# CORS — when serving the SPA from the same origin (production), keep "*".
# When the frontend lives elsewhere, list the exact origins, comma-separated.
CORS_ORIGINS=*

# Set to "false" to skip auto-seed on startup.
HELM_AUTO_SEED=true

# Anthropic API key — required for AI Resolver / chat / contract ingestion.
# Get one at https://console.anthropic.com/settings/keys. Leave blank to disable.
ANTHROPIC_API_KEY=
